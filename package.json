{
  "name": "shader-forge",
  "private": true,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexkenley/shader-forge.git"
  },
  "homepage": "https://github.com/alexkenley/shader-forge",
  "bugs": {
    "url": "https://github.com/alexkenley/shader-forge/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "engine": "node tools/engine-cli/shaderforge.mjs",
    "sessiond:start": "node tools/engine-cli/shaderforge.mjs sessiond start",
    "shell:serve": "node scripts/serve-engine-shell.mjs",
    "shell:dev": "npm --prefix shell/engine-shell run dev",
    "shell:build": "npm --prefix shell/engine-shell run build",
    "shell:typecheck": "npm --prefix shell/engine-shell run typecheck",
    "test": "node scripts/test-engine-shell-smoke.mjs",
    "test:harness": "node scripts/test-engine-shell-smoke.mjs",
    "test:shell-smoke": "node scripts/test-engine-shell-smoke.mjs",
    "test:sessiond": "node scripts/test-engine-sessiond.mjs",
    "test:runtime-scaffold": "node scripts/test-engine-runtime-scaffold.mjs",
    "test:data-foundation-scaffold": "node scripts/test-engine-data-foundation-scaffold.mjs",
    "test:asset-pipeline": "node scripts/test-engine-asset-pipeline.mjs",
    "test:migration-fixtures": "node scripts/test-engine-migration-fixtures.mjs",
    "test:audio-scaffold": "node scripts/test-engine-audio-scaffold.mjs",
    "test:animation-scaffold": "node scripts/test-engine-animation-scaffold.mjs",
    "test:physics-scaffold": "node scripts/test-engine-physics-scaffold.mjs",
    "test:input-scaffold": "node scripts/test-engine-input-scaffold.mjs",
    "test:save-system-scaffold": "node scripts/test-engine-save-system-scaffold.mjs",
    "test:tooling-ui-scaffold": "node scripts/test-engine-tooling-ui-scaffold.mjs",
    "test:scene-authoring": "node scripts/test-engine-scene-authoring.mjs",
    "test:scene-runtime-scaffold": "node scripts/test-engine-scene-runtime-scaffold.mjs",
    "test:viewer-bridge": "node scripts/test-engine-viewer-bridge.mjs",
    "test:ollama-smoke": "node scripts/test-ollama-smoke.mjs"
  },
  "dependencies": {
    "node-pty": "^1.1.0"
  }
}
